# ─── Required ───────────────────────────────────────────────────────────────

# Google Gemini API key — powers Agent, the AI shopping assistant.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Recommended (production) ───────────────────────────────────────────────

# Public site URL — used for Open Graph links, sitemap, and social previews.
# Example: https://agent.kapruka.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
