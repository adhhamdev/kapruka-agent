# ─── Required ───────────────────────────────────────────────────────────────

# Google Gemini API key — powers Agent, the AI shopping assistant.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Recommended (production) ───────────────────────────────────────────────

# Public site URL — used for Open Graph links, sitemap, and social previews.
# MUST be your production HTTPS domain or WhatsApp/Discord won't load preview images.
# Example: https://agent-kapruka.vercel.app
NEXT_PUBLIC_APP_URL=https://agent-kapruka.vercel.app

# SuperMemory API key — powers the agent's memory.
SUPERMEMORY_API_KEY=